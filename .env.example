# Copy this file to .env and adjust variables as needed

# The port the backend server will run on
APP_PORT=1231

# Standard Python log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Optional: Absolute path to the cloudflared binary
# If empty, the system will try to find it in common paths (/opt/homebrew/bin or /usr/local/bin)
CLOUDFLARED_PATH=

# SQLite database connection string
DATABASE_URL=sqlite+aiosqlite:///./tunnels.db

# API Token for securing tunnel management endpoints
API_TOKEN=change-me-in-production



